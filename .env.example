# Copy this file to .env and replace placeholder values before deployment.

# Django
SECRET_KEY=replace-with-a-long-random-secret
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,testserver

# Database
# Local dev (SQLite): leave DATABASE_URL empty.
# Production (Postgres): postgres://user:password@host:5432/dbname
DATABASE_URL=
DB_SSLMODE=require

# Frontend origins allowed to call backend API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# HTTPS behavior (production)
SECURE_SSL_REDIRECT=True

# JWT (application defaults can be overridden by wiring these in settings)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=False
JWT_BLACKLIST_AFTER_ROTATION=False
JWT_AUTH_HEADER_TYPES=Bearer
